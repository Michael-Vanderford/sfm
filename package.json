{
    "name": "sfm",
    "version": "1.0.0",
    "description": "String File Manager",
    "homepage": "https://github.com/michael-vanderford/sfm",
    "main": "src/main/main.js",
    "scripts": {
        "start": "electron . --no-sandbox",
        "build": "npx electron-builder --linux",
        "postinstall": "electron-rebuild",
        "test": "jest"
    },
    "build": {
        "appId": "com.stringboard.sfm",
        "linux": {
            "target": [
                "deb"
            ],
            "executableName": "sfm"
        }
    },
    "author": {
        "name": "Michael Vanderford",
        "email": "michael.vanderford@gmail.com"
    },
    "license": "LGPL-2.1-or-later",
    "devDependencies": {
        "bootstrap-icons": "^1.11.3",
        "electron": "^37.10.3",
        "jest": "^29.7.0",
        "node-gyp": "^11.4.2"
    },
    "dependencies": {
        "archiver": "^7.0.1",
        "fast-xml-parser": "^5.4.1",
        "material-design-icons": "^3.0.1",
        "nan": "^2.22.0"
    }
}
